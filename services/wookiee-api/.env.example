# Copy to .env locally, or set these as real environment variables /
# Dokploy secrets in production - never commit actual values.

# Long random string. Encrypts data/secrets.enc at rest - losing this means
# losing every stored key with no recovery path, so back it up somewhere
# safe (a password manager, not another file in this repo).
MASTER_KEY=

# Long random string. WordPress sends this as the X-Api-Key header on every
# request to this service.
API_SHARED_SECRET=

# Password for the browser-facing admin UI (HTTP Basic Auth - any username,
# this password). Also used to sign/verify the Google OAuth "state" param.
ADMIN_PASSWORD=

PORT=3000

# --- Optional: provider keys, settable here instead of through the admin UI ---
# Any of these left blank can still be filled in later via the settings page
# at https://<this-service>/ - whichever was saved there most recently wins.
# Fill in only the ones you actually have; everything else stays blank/off.

COMPANIES_HOUSE_API_KEY=

LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_DEFAULT_MODEL=gpt-4o-mini

CJ_EMAIL=
CJ_API_KEY=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
REMBG_ENDPOINT_URL=http://rembg:7000

GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

SPACESHIP_API_KEY=
SPACESHIP_API_SECRET=
